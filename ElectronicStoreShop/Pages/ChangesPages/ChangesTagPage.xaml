<Page x:Class="ElectronicStoreShop.Pages.ChangesPages.ChangesTagPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ElectronicStoreShop.Pages.ChangesPages"
      xmlns:validation="clr-namespace:ElectronicStoreShop.Validation"
      mc:Ignorable="d" 
      Style="{StaticResource MainPageStyle}"
      Title="Управление тегами">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Margin="10">
            <Label Content="Управление тегами" 
                   Style="{StaticResource WindowTitleLabelStyle}"
                   HorizontalAlignment="Left"/>
            <Button Content="Назад" 
                    Click="Back_Click"
                    Style="{StaticResource GoBackButtonStyle}"
                    HorizontalAlignment="Right"/>
        </Grid>

        <Border Grid.Column="0" Grid.Row="1" Style="{StaticResource ManagementSectionBorderStyle}">
            <StackPanel>


                <TextBlock Text="Название тега" Style="{StaticResource ProductDescriptionMenuChangeTextStyle}"/>
                <TextBox Style="{StaticResource FormTextBoxStyle}" x:Name="NameTagTextBox">
                    <Binding Path="TagName" UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <validation:EmptyFieldValidation/>
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox>

                <Button Content="Добавить тег" 
                        Style="{StaticResource AddButtonObStyle}"
                        Click="SaveTag_Click"/>

                <Button Content="Отмена" 
        Style="{StaticResource AddButtonObStyle}"
        Click="CancelTag_Click"/>

            </StackPanel>
        </Border>

        <Border Grid.Column="1" Grid.Row="1" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1" 
                CornerRadius="4"
                Margin="5,0,10,10"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
            </Grid>
        </Border>
    </Grid>
</Page>