<Page x:Class="ElectronicStoreShop.Pages.ChangesPages.ViewChangesTags"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ElectronicStoreShop.Pages.ChangesPages"
      mc:Ignorable="d" 
      Style="{StaticResource MainPageStyle}"
      Title="Изменения тегов">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <Grid Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2"  >
            <Label Content="Изменения тегов" 
           Style="{StaticResource WindowTitleLabelStyle}"
           HorizontalAlignment="Left"/>

            <Button Content="Назад" 
            Style="{StaticResource GoBackButtonStyle}"
            Click="Back_Click"/>
        </Grid>
        <StackPanel Grid.Column="0" Grid.Row="1" Style="{StaticResource StackPanelStyleProduct}">
            <Button Content="Добавить тег" 
    Style="{StaticResource AddButtonStyle}" 
    Click="AddTag_Click"/>

            <Button Content="Изменить тег" 
    Style="{StaticResource EditButtonStyle}" 
    Click="EditTag_Click"/>

            <Button Content="Удалить тег" 
    Style="{StaticResource DeleteButtonStyle}"
    Click="DeleteTag_Click"/>
        </StackPanel>


        <ListView Grid.Row="1" Grid.Column="1"
            x:Name="TagsListView"
            ItemsSource="{Binding Tags}"
            SelectionChanged="TagsListView_SelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource ChangesSectionBorderStyle}">

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <!-- Название тега -->
                                <TextBlock Text="{Binding Name}" 
                                 FontWeight="Bold"
                                 FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
