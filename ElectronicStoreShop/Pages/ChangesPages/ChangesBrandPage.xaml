<Page x:Class="ElectronicStoreShop.Pages.ChangesPages.ChangesBrandPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:validation="clr-namespace:ElectronicStoreShop.Validation"
      xmlns:local="clr-namespace:ElectronicStoreShop.Pages.ChangesPages"
      Style="{StaticResource MainPageStyle}"
      mc:Ignorable="d" 
      Title="Управление брендами">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Margin="10">
            <Label Content="Управление брендами" 
            Style="{StaticResource WindowTitleLabelStyle}"
            HorizontalAlignment="Left"/>
            <Button Content="Назад" 
             Click="Back_Click"
             Style="{StaticResource GoBackButtonStyle}"
             HorizontalAlignment="Right"/>
        </Grid>

        <Border Grid.Column="0" Grid.Row="1" Style="{StaticResource ManagementSectionBorderStyle}">
            <StackPanel>

                <TextBlock Text="Название бренд" Style="{StaticResource ProductDescriptionMenuChangeTextStyle}"/>
                <TextBox Style="{StaticResource FormTextBoxStyle}" x:Name="NameBrandTextBox">
                    <Binding Path="BrandName" UpdateSourceTrigger="PropertyChanged">
                        <Binding.ValidationRules>
                            <validation:EmptyFieldValidation/>
                        </Binding.ValidationRules>
                    </Binding>
                </TextBox>

                <Button Content="Добавить бренд" 
                 Style="{StaticResource AddButtonObStyle}"
                 Click="SaveBrand_Click"/>

                <Button Content="Отмена" 
                 Style="{StaticResource AddButtonObStyle}"
                 Click="CancelBrand_Click"/>

            </StackPanel>
        </Border>

    </Grid>
</Page>
