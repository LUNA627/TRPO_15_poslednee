<Page x:Class="ElectronicStoreShop.Pages.ChangesPages.ViewChangesBrands"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:ElectronicStoreShop.Pages.ChangesPages"
      mc:Ignorable="d" 
      Style="{StaticResource MainPageStyle}"
      Title="Изменения брендов">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2">
            <Label Content="Изменения брендов" 
           Style="{StaticResource WindowTitleLabelStyle}"
           HorizontalAlignment="Left"/>

            <Button Content="Назад" 
            Style="{StaticResource GoBackButtonStyle}"
            Click="Back_Click"/>
        </Grid>
      
        <StackPanel Grid.Column="0" Grid.Row="1" Style="{StaticResource StackPanelStyleProduct}">
            <Button Content="Добавить бренд" 
    Style="{StaticResource AddButtonStyle}" 
    Click="AddBrand_Click"/>

            <Button Content="Изменить бренд" 
    Style="{StaticResource EditButtonStyle}" 
    Click="EditBrand_Click"/>

            <Button Content="Удалить бренд" 
    Style="{StaticResource DeleteButtonStyle}"
    Click="DeleteBrand_Click"/>
        </StackPanel>


        <ListView Grid.Column="1" Grid.Row="1" 
          x:Name="BrandsListView"
          ItemsSource="{Binding Brands}"
          SelectionMode="Single"
          Margin="5,0,10,10">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource ChangesSectionBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <!--  категории -->
                                <TextBlock Text="{Binding Name}" 
                                   FontWeight="Bold"
                                   FontSize="14"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
