<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Style x:Key="StackPanelStylePassword" TargetType="StackPanel">

        <Setter Property="Margin" Value="5"/>
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Width" Value="390"/>
    </Style>
    
    <Style x:Key="StackPanelStyleExitManager" TargetType="StackPanel">

        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Width" Value="370"/>
    </Style>

    <Style x:Key="StackPanelStyleRadioBtn" TargetType="StackPanel">

        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Width" Value="200"/>

    </Style>


    <Style x:Key="StackPanelStyleStock" TargetType="StackPanel">

        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Width" Value="200"/>
    </Style>

    <!-- Панель для фильтров -->
    <Style x:Key="FilterPanelStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Background" Value="#F5F5F5"/>
    </Style>


    <Style x:Key="StackPanelStyleAddProduct" TargetType="StackPanel">

        <Setter Property="Orientation" Value="Vertical"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Width" Value="900"/>

    </Style>

    <Style x:Key="StackPanelStyleProduct" TargetType="StackPanel">

        <Setter Property="Orientation" Value="Vertical"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="10"/>


    </Style>


    <Style x:Key="FilterFPanelStyle" TargetType="StackPanel">
        <Setter Property="Margin" Value="10"/>
        <Setter Property="Background" Value="#dfeaeb"/>
    </Style>
    
</ResourceDictionary>