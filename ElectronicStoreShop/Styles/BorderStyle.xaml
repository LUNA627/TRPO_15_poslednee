<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Border для секции фильтра -->
    <Style x:Key="FilterSectionBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="White"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#E0E0E0"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- Border для секции пароля -->
    <Style x:Key="PasswordSectionBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderThickness" Value="3"/>
        <Setter Property="BorderBrush" Value="#00b4c4"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- Border для секции главная -->
    <Style x:Key="MainSectionBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderThickness" Value="3"/>
        <Setter Property="BorderBrush" Value="#00b4c4"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- Border для секции управления -->
    <Style x:Key="ManagementSectionBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#00b4c4"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Margin" Value="10,0,5,10"/>
        
    </Style>

    <!-- Border для секции отображения -->
    <Style x:Key="LookSectionBorderStyle" TargetType="Border"
           BasedOn="{StaticResource ProductCardBorderStyle}">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="#00b4c4"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Margin" Value="2"/>

    </Style>


    <!-- Border для секции изменения -->
    <Style x:Key="ChangesSectionBorderStyle" TargetType="Border"
           BasedOn="{StaticResource ProductCardBorderStyle}">
        
        <Setter Property="BorderBrush" Value="#00b4c4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Padding" Value="10"/>
  

    </Style>

</ResourceDictionary>