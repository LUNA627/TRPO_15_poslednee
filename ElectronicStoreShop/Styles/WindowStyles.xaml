<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Основная страница -->
    <Style x:Key="MainPageStyle" TargetType="Page">
        <Setter Property="Background" Value="#dfeaeb"/>
        <Setter Property="MinHeight" Value="600"/>
        <Setter Property="MinWidth" Value="1000"/>
    </Style>

    <!-- Основная страница -->
    <Style x:Key="MainPageProductStyle" TargetType="Page">
        <Setter Property="Background" Value="#dfeaeb"/>
        <Setter Property="MinHeight" Value="800"/>
        <Setter Property="MinWidth" Value="1000"/>
    </Style>

    <!-- Окно ввода пароля -->
    <Style x:Key="ManagerWindowsStyle" TargetType="Window">
        <Setter Property="Background" Value="#dfeaeb"/>
        <Setter Property="Height" Value="450"/>
        <Setter Property="Width" Value="800"/>
    </Style>

    
</ResourceDictionary>