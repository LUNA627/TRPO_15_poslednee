<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Заголовок товара -->
    <Style x:Key="ProductTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Описание товара -->
    <Style x:Key="ProductDescriptionTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#666666"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,2,0,5"/>
    </Style>

    <!-- Цена товара -->
    <Style x:Key="ProductPriceTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="#00C4B4"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
    </Style>

    <!-- Информация о товаре -->
    <Style x:Key="ProductInfoTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#666666"/>
        <Setter Property="Margin" Value="0,1"/>
    </Style>
    
    <!-- Информация о теги -->
    <Style x:Key="TagInfoTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="#666666"/>
        <Setter Property="Margin" Value="0,1"/>
        <Setter Property="FontStyle" Value="Italic"/>
    </Style>
    <!-- Информация о остатке -->
    <Style x:Key="StrockInfoTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#666666"/>
        <Setter Property="Margin" Value="0,1"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <!-- Статус (количество записей) -->
    <Style x:Key="StatusTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="#666666"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="5,0"/>
    </Style>

    <!-- Заголовок секции фильтра -->
    <Style x:Key="FilterSectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#333333"/>
        <Setter Property="Margin" Value="0,0,0,5"/>
    </Style>


    <!-- Текст разделителя цены (тире) -->
    <Style x:Key="PriceSeparatorTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Foreground" Value="#999999"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>


    <!-- Описание товара (меню изменений) -->
    <Style x:Key="ProductDescriptionMenuChangeTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="#666666"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,25,0,5"/>
    </Style>
</ResourceDictionary>